{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "TabRest",
  "description": "Automatically suspend inactive tabs to save memory and keep your browser fast.",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "TabRest — Tab Suspension"
  },
  "options_page": "options/index.html",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "author": "FabyoSK"
}